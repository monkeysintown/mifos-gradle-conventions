<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="credit-scoring-collaboration">
    <bpmn:participant id="participant-frontend" name="CREDIT_SCORING_FRONTEND_(BANK)" processRef="frontend-process" />
    <bpmn:participant id="participant-credit-scoring" name="CREDIT_SCORING_(BANK)" processRef="credit-scoring-process" />
    <bpmn:participant id="participant-scoring-service" name="SCORING_SERVICE" processRef="scoring-service-process" />
    <bpmn:messageFlow id="msg-frontend-to-scoring" sourceRef="participant-frontend" targetRef="start-scoring-request-received" />
    <bpmn:messageFlow id="msg-report-delay-to-frontend" sourceRef="task-report-delay" targetRef="participant-frontend" />
    <bpmn:messageFlow id="msg-send-score-to-frontend" sourceRef="task-send-credit-score" targetRef="participant-frontend" />
    <bpmn:messageFlow id="msg-request-to-service" sourceRef="task-request-credit-score" targetRef="start-service-request-received" />
    <bpmn:messageFlow id="msg-service-score-direct" sourceRef="task-send-score-direct" targetRef="event-score-received-direct" />
    <bpmn:messageFlow id="msg-service-score-after-delay" sourceRef="task-send-score-after-delay" targetRef="event-score-received-after-delay" />
    <bpmn:messageFlow id="msg-service-delay-info" sourceRef="task-report-service-delay" targetRef="event-delay-info-received" />
  </bpmn:collaboration>

  <bpmn:message id="msg-scoring-request" name="SCORING_REQUEST" />
  <bpmn:message id="msg-service-request" name="SERVICE_SCORING_REQUEST" />
  <bpmn:message id="msg-score-direct" name="CREDIT_SCORE_DIRECT" />
  <bpmn:message id="msg-score-delayed" name="CREDIT_SCORE_AFTER_DELAY" />
  <bpmn:message id="msg-delay-info" name="DELAY_INFORMATION" />

  <bpmn:process id="frontend-process" isExecutable="false" />

  <bpmn:process id="credit-scoring-process">
    <bpmn:task id="task-request-credit-score" name="REQUEST_CREDIT_SCORE">
      <bpmn:incoming>flow-start-to-request</bpmn:incoming>
      <bpmn:outgoing>flow-request-to-gateway</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="gateway-merge-responses" name="MERGE_RESPONSE_PATHS">
      <bpmn:incoming>flow-score-delayed-to-merge</bpmn:incoming>
      <bpmn:incoming>flow-score-direct-to-merge</bpmn:incoming>
      <bpmn:outgoing>flow-merge-to-send</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="task-send-credit-score" name="SEND_CREDIT_SCORE_TO_FRONTEND">
      <bpmn:incoming>flow-merge-to-send</bpmn:incoming>
      <bpmn:outgoing>flow-send-to-end</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="end-scoring-handled" name="SCORING_REQUEST_HANDLED">
      <bpmn:incoming>flow-send-to-end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="task-report-delay" name="REPORT_DELAY_TO_FRONTEND">
      <bpmn:incoming>flow-delay-to-report</bpmn:incoming>
      <bpmn:outgoing>flow-report-to-score-after-delay</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="flow-start-to-request" sourceRef="start-scoring-request-received" targetRef="task-request-credit-score" />
    <bpmn:sequenceFlow id="flow-score-delayed-to-merge" sourceRef="event-score-received-after-delay" targetRef="gateway-merge-responses" />
    <bpmn:sequenceFlow id="flow-score-direct-to-merge" sourceRef="event-score-received-direct" targetRef="gateway-merge-responses" />
    <bpmn:sequenceFlow id="flow-merge-to-send" sourceRef="gateway-merge-responses" targetRef="task-send-credit-score" />
    <bpmn:sequenceFlow id="flow-send-to-end" sourceRef="task-send-credit-score" targetRef="end-scoring-handled" />
    <bpmn:sequenceFlow id="flow-delay-to-report" sourceRef="event-delay-info-received" targetRef="task-report-delay" />
    <bpmn:sequenceFlow id="flow-report-to-score-after-delay" sourceRef="task-report-delay" targetRef="event-score-received-after-delay" />
    <bpmn:intermediateCatchEvent id="event-score-received-direct" name="CREDIT_SCORE_RECEIVED">
      <bpmn:incoming>flow-gateway-to-score-direct</bpmn:incoming>
      <bpmn:outgoing>flow-score-direct-to-merge</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="msg-score-direct" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="event-score-received-after-delay" name="CREDIT_SCORE_RECEIVED">
      <bpmn:incoming>flow-report-to-score-after-delay</bpmn:incoming>
      <bpmn:outgoing>flow-score-delayed-to-merge</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="msg-score-delayed" />
    </bpmn:intermediateCatchEvent>
    <bpmn:startEvent id="start-scoring-request-received" name="SCORING_REQUEST_RECEIVED">
      <bpmn:outgoing>flow-start-to-request</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="msg-scoring-request" />
    </bpmn:startEvent>
    <bpmn:intermediateCatchEvent id="event-delay-info-received" name="DELAY_INFORMATION_RECEIVED">
      <bpmn:incoming>flow-gateway-to-delay</bpmn:incoming>
      <bpmn:outgoing>flow-delay-to-report</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="msg-delay-info" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="flow-request-to-gateway" sourceRef="task-request-credit-score" targetRef="gateway-await-response" />
    <bpmn:eventBasedGateway id="gateway-await-response" name="AWAIT_SCORING_RESPONSE">
      <bpmn:incoming>flow-request-to-gateway</bpmn:incoming>
      <bpmn:outgoing>flow-gateway-to-delay</bpmn:outgoing>
      <bpmn:outgoing>flow-gateway-to-score-direct</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:sequenceFlow id="flow-gateway-to-delay" sourceRef="gateway-await-response" targetRef="event-delay-info-received" />
    <bpmn:sequenceFlow id="flow-gateway-to-score-direct" sourceRef="gateway-await-response" targetRef="event-score-received-direct" />
  </bpmn:process>

  <bpmn:process id="scoring-service-process">
    <bpmn:sequenceFlow id="flow-no-to-report-delay" name="NO" sourceRef="gateway-score-available" targetRef="task-report-service-delay" />
    <bpmn:sequenceFlow id="flow-yes-to-send-direct" name="YES" sourceRef="gateway-score-available" targetRef="task-send-score-direct" />
    <bpmn:sequenceFlow id="flow-merge-to-end" sourceRef="gateway-service-end" targetRef="end-service-handled" />
    <bpmn:sequenceFlow id="flow-send-delayed-to-end" sourceRef="task-send-score-after-delay" targetRef="gateway-service-end" />
    <bpmn:sequenceFlow id="flow-send-direct-to-end" sourceRef="task-send-score-direct" targetRef="gateway-service-end" />
    <bpmn:sequenceFlow id="flow-l2-to-send" sourceRef="task-compute-score-level-2" targetRef="task-send-score-after-delay" />
    <bpmn:sequenceFlow id="flow-delay-to-compute-l2" sourceRef="task-report-service-delay" targetRef="task-compute-score-level-2" />
    <bpmn:sequenceFlow id="flow-l1-to-check" sourceRef="task-compute-score-level-1" targetRef="gateway-score-available" />
    <bpmn:sequenceFlow id="flow-start-to-compute-l1" sourceRef="start-service-request-received" targetRef="task-compute-score-level-1" />
    <bpmn:task id="task-send-score-direct" name="SEND_CREDIT_SCORE_TO_FRONTEND">
      <bpmn:incoming>flow-yes-to-send-direct</bpmn:incoming>
      <bpmn:outgoing>flow-send-direct-to-end</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task-report-service-delay" name="REPORT_DELAY_TO_FRONTEND">
      <bpmn:incoming>flow-no-to-report-delay</bpmn:incoming>
      <bpmn:outgoing>flow-delay-to-compute-l2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="gateway-score-available" name="SCORE_AVAILABLE?">
      <bpmn:incoming>flow-l1-to-check</bpmn:incoming>
      <bpmn:outgoing>flow-no-to-report-delay</bpmn:outgoing>
      <bpmn:outgoing>flow-yes-to-send-direct</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="task-send-score-after-delay" name="SEND_CREDIT_SCORE_TO_FRONTEND">
      <bpmn:incoming>flow-l2-to-send</bpmn:incoming>
      <bpmn:outgoing>flow-send-delayed-to-end</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="end-service-handled" name="SCORING_REQUEST_HANDLED">
      <bpmn:incoming>flow-merge-to-end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="gateway-service-end" name="MERGE_END_PATHS">
      <bpmn:incoming>flow-send-direct-to-end</bpmn:incoming>
      <bpmn:incoming>flow-send-delayed-to-end</bpmn:incoming>
      <bpmn:outgoing>flow-merge-to-end</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="task-compute-score-level-2" name="COMPUTE_CREDIT_SCORE_(LEVEL_2)">
      <bpmn:incoming>flow-delay-to-compute-l2</bpmn:incoming>
      <bpmn:outgoing>flow-l2-to-send</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task-compute-score-level-1" name="COMPUTE_CREDIT_SCORE_(LEVEL_1)">
      <bpmn:incoming>flow-start-to-compute-l1</bpmn:incoming>
      <bpmn:outgoing>flow-l1-to-check</bpmn:outgoing>
    </bpmn:task>
    <bpmn:startEvent id="start-service-request-received" name="SCORING_REQUEST_RECEIVED">
      <bpmn:outgoing>flow-start-to-compute-l1</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="msg-service-request" />
    </bpmn:startEvent>
    <bpmn:association id="assoc-delay-note" sourceRef="task-report-service-delay" targetRef="annotation-delay-queue" />
    <bpmn:textAnnotation id="annotation-delay-queue">
      <bpmn:text><![CDATA[INCL._ID_FOR_MESSAGE_QUEUEING]]></bpmn:text>
    </bpmn:textAnnotation>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="bpmn-diagram-1">
    <bpmndi:BPMNPlane id="bpmn-plane-1" bpmnElement="credit-scoring-collaboration">
      <bpmndi:BPMNShape id="participant-frontend-di" bpmnElement="participant-frontend">

      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="task-report-service-delay-di" bpmnElement="task-report-service-delay">
        <dc:Bounds x="648" y="847" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task-compute-score-level-2-di" bpmnElement="task-compute-score-level-2">
        <dc:Bounds x="825" y="847" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="flow-delay-to-compute-l2-di" bpmnElement="flow-delay-to-compute-l2">
        <di:waypoint xsi:type="dc:Point" x="748" y="887" />
        <di:waypoint xsi:type="dc:Point" x="825" y="887" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="764" y="877" width="90" height="20" />

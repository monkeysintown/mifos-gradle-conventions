@startuml
!theme plain

' ============================================================
' COOLORS DRAMATIC THEME — Presentation Optimized
' Palette: https://coolors.co/00193a-002b53-023f73-034780-7a0213-a10220-bf0a26-cd0c2b-131313-262626
' Navy / Red / Black high-contrast dramatic
' ============================================================

skinparam backgroundColor #F8F9FA

' --- Global Typography ---
skinparam defaultFontName "Segoe UI", "Helvetica Neue", Arial, sans-serif
skinparam defaultFontSize 14
skinparam defaultFontColor #00193A

' ============================================================
' PALETTE ASSIGNMENT
' ============================================================
' #00193A — Deepest navy    — Primary text, titles, darkest borders
' #002B53 — Dark navy       — Class borders, participant borders
' #023F73 — Medium navy     — State/activity borders, components
' #034780 — Bright navy     — Interface borders, control borders
' #7A0213 — Dark red        — Abstract borders, error states
' #A10220 — Strong red      — Enum borders, entity borders
' #BF0A26 — Bright red      — Notes, alerts, highlights
' #CD0C2B — Vivid red       — Stereotypes, accents
' #131313 — Near black      — Secondary text, arrows
' #262626 — Dark gray       — Arrow labels, secondary elements
'
' Background tints
' Navy tint:  #E6EEF7
' Red tint:   #FDE8EC
' Gray tint:  #F0F0F0

' ============================================================
' ARROWS
' ============================================================
skinparam arrowColor #131313
skinparam arrowThickness 1.5
skinparam arrowFontSize 11
skinparam arrowFontColor #262626
skinparam arrowLollipopColor #131313

' ============================================================
' CLASS DIAGRAM
' ============================================================
skinparam class {
    BackgroundColor #FFFFFF
    BorderColor #002B53
    FontColor #00193A
    FontSize 14
    FontName "Segoe UI", "Helvetica Neue", Arial
    BorderThickness 2
    Shadowing false
    RoundCorner 10
    AttributeFontSize 12
    AttributeFontColor #023F73
    StereotypeFontSize 11
    StereotypeFontColor #034780
}

' --- Interface (#034780) ---
skinparam interface {
    BackgroundColor #E6EEF7
    BorderColor #034780
    FontColor #00193A
    BorderThickness 2
}

' --- Enum (#A10220) ---
skinparam enum {
    BackgroundColor #FDE8EC
    BorderColor #A10220
    FontColor #00193A
    BorderThickness 2
}

' --- Abstract (#7A0213) ---
skinparam abstract {
    BackgroundColor #FDE8EC
    BorderColor #7A0213
    FontColor #00193A
    BorderThickness 2
}

' --- Notes (#BF0A26) ---
skinparam note {
    BackgroundColor #FDE8EC
    BorderColor #BF0A26
    FontColor #00193A
    FontSize 12
    BorderThickness 1.5
    RoundCorner 8
}

' --- Packages (#023F73) ---
skinparam package {
    BackgroundColor #E6EEF7
    BorderColor #023F73
    FontColor #00193A
    FontSize 14
    BorderThickness 1.5
    RoundCorner 12
}

' ============================================================
' SEQUENCE DIAGRAM
' ============================================================
skinparam sequence {
    ArrowColor #131313
    ArrowThickness 1.5
    ActorBorderColor #002B53
    LifeLineBorderColor #023F73
    LifeLineBackgroundColor #E6EEF7
    ParticipantBorderColor #002B53
    ParticipantBackgroundColor #FFFFFF
    ParticipantFontSize 13
    ParticipantFontColor #00193A
    ActorBackgroundColor #FFFFFF
    ActorFontSize 13
    ActorFontColor #00193A
    MessageAlignment center
    BoxBackgroundColor #E6EEF7
    BoxBorderColor #023F73
    DividerBackgroundColor #E6EEF7
    DividerBorderColor #023F73
    DividerFontSize 12
    DividerFontColor #002B53
    GroupBackgroundColor #E6EEF7
    GroupBorderColor #023F73
    GroupFontSize 12
    GroupFontColor #002B53
    ReferenceBackgroundColor #FDE8EC
    ReferenceBorderColor #BF0A26
    ReferenceFontSize 12
    ReferenceFontColor #00193A
    DelayFontColor #023F73
    DelayFontSize 11
}

' ============================================================
' USE CASE
' ============================================================
skinparam usecase {
    BackgroundColor #FFFFFF
    BorderColor #002B53
    FontColor #00193A
    FontSize 13
    BorderThickness 1.5
}

skinparam actor {
    BackgroundColor #002B53
    BorderColor #002B53
    FontColor #002B53
    FontSize 13
}

' ============================================================
' ACTIVITY DIAGRAM
' ============================================================
skinparam activity {

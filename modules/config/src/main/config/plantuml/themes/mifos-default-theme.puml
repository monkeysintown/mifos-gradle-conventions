    DiamondBorderColor #002B53
    DiamondFontColor #00193A
    BarColor #002B53
    StartColor #034780
    EndColor #BF0A26
    BorderColor #002B53
}

skinparam partition {
    BorderColor #023F73
    BackgroundColor #E6EEF7
    FontColor #002B53
    FontSize 12
    RoundCorner 6
}

' ============================================================
' STATE DIAGRAM
' ============================================================
skinparam state {
    BackgroundColor #FFFFFF
    BorderColor #002B53

' ============================================================
' TITLE & METADATA
' ============================================================
skinparam title {
    FontSize 20
    FontColor #00193A
    FontName "Segoe UI", "Helvetica Neue", Arial
}

skinparam header {
    FontSize 10
    FontColor #023F73
}

skinparam footer {
    FontSize 10
    FontColor #023F73
}

skinparam legend {
    BackgroundColor #FFFFFF
    BorderColor #023F73
    FontColor #002B53

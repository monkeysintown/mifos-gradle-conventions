}

' ============================================================
' STEREOTYPE COLORS
' ============================================================
skinparam stereotypeCBackgroundColor #034780
skinparam stereotypeABackgroundColor #7A0213
skinparam stereotypeIBackgroundColor #034780
skinparam stereotypeEBackgroundColor #A10220

' ============================================================
' LAYOUT
' ============================================================
skinparam linetype ortho
skinparam wrapWidth 220
skinparam maxMessageSize 160
skinparam Padding 5

@enduml
@startuml fineract-current-overview
skinparam componentStyle rectangle
skinparam nodesep 60
skinparam ranksep 60

title Apache Fineract — Current Cross-Feature Dependencies\n(Red = violation of target boundary rule)

' --- Fully independent (already compliant) ---
package "✅ Already Independent" #LightGreen {
    [F9  charge] as F9
    [F10 calendar] as F10
    [F11 rate] as F11
    [F13 organisation] as F13
    [F19 notifications] as F19
    [F20 template] as F20
}

' --- Near-independent ---
package "🟢 Near-Independent" #PaleGreen {
    [F1  accounting] as F1
    [F2  client] as F2
    [F12 account-transfers] as F12
    [F16 useradministration] as F16
    [F17 mix] as F17
}

' --- Moderate coupling ---
package "🟡 Moderate" #LightYellow {
    [F3  group] as F3
    [F8  shareaccounts] as F8
    [F14 teller] as F14
    [F15 report] as F15
    [F18 batch] as F18
}

' --- Highly coupled ---
package "🔴 Highly Coupled" #LightPink {
    [F4  loan] as F4
    [F5  savings] as F5
    [F6  fixeddeposit] as F6
    [F7  recurringdeposit] as F7
}

' --- Allowed dependencies ---
package "Allowed" #E8E8E8 {
    [fineract-core] as CORE
    [fineract-command] as CMD
}

